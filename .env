# ================================
# AI Procurement Data Processor - Environment Configuration
# ================================

# Groq AI API Configuration

# Application Configuration
MAX_FILE_SIZE_MB=50
API_TIMEOUT=30
MAX_RETRIES=3

# Logging Configuration
LOG_LEVEL=INFO

# Streamlit Configuration (Optional)
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# Data Processing Configuration
CHUNK_SIZE=1000
MIN_PRICE=0.0
MAX_PRICE=1000000.0

# EAN Detection Configuration
# Enable universal EAN detection (recommended: true)
UNIVERSAL_EAN_DETECTION=true

# Fallback detection when AI is not available
FALLBACK_DETECTION=true

DEBUG_MODE=false
